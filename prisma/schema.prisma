generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  password  String
  role      String   @default("obra") // "admin" | "obra"
  createdAt DateTime @default(now())
}

model Visit {
  id        String   @id @default(cuid())
  date      DateTime
  visitor   String
  type      String   // "visita" | "vistoria"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
