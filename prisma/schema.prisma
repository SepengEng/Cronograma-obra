generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Visit {
  id        String   @id @default(cuid())
  date      DateTime
  visitor   String
  type      String   // "visita" | "vistoria"
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
