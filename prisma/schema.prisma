generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  password  String
  role      String   @default("obra") // "admin" | "obra"
  createdAt DateTime @default(now())
}

model Visit {
  id        String   @id @default(cuid())
  date      DateTime
  visitor   String
  type      String   // "visita" | "vistoria"
  notes     String?
  status    String   @default("pendente") // "pendente" | "concluida" | "nao_realizada"
  unitId    String?
  unit      Unit?    @relation(fields: [unitId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id        String   @id @default(cuid())
  number    String   @unique
  floor     Int
  position  Int
  tower     String   @default("Torre Única")
  status    String   @default("sem_vistoria") // "sem_vistoria" | "agendada" | "concluida" | "pendencia" | "indisponivel"
  notes     String?
  visits    Visit[]
  updatedAt DateTime @updatedAt
}
