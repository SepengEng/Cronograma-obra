generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String   @unique
  password  String
  role      String   @default("obra") // "admin" | "obra"
  createdAt DateTime @default(now())
}

model Visit {
  id        String   @id @default(cuid())
  date      DateTime
  visitor   String
  type      String   // "visita" | "vistoria"
  notes     String?
  status    String   @default("pendente") // "pendente" | "concluida" | "nao_realizada"
  unitId    String?
  unit      Unit?    @relation(fields: [unitId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Unit {
  id          String   @id @default(cuid())
  number      String   @unique
  floor       Int
  position    Int
  tower       String   @default("Torre Única")
  status      String   @default("sem_vistoria") // "sem_vistoria" | "agendada" | "concluida" | "pendencia" | "indisponivel"
  notes       String?
  responsavel String?
  pendencias  String?  // JSON: [{id,text,done}]

  // Proprietário
  email        String?
  telefone     String?
  cpf          String?

  // Financiamento
  situacao     String?  // FINANCIADO | QUITADO | ALIENAÇÃO FIDUCIÁRIA | QUITAR À VISTA
  valorPago    Float?
  saldoDevedor Float?

  // Contrato
  contratoUrl   String?
  contratoNotes String?

  // Checklists detalhados (JSON: [{id,text,done}])
  previstoria   String?
  vistoriaCheck String?

  // Entrega de chaves (JSON: {docs:[{id,text,done}], dataEntrega, assinaturaNome, assinaturaData, assinaturaImg})
  entregaChaves String?

  // Pós-obra (JSON: [{id,titulo,descricao,status,resposta,aceito,createdAt}])
  posObra String?

  // Portal do proprietário (token do link único)
  portalToken String? @unique

  visits        Visit[]
  contratoFiles ContratoFile[]
  updatedAt     DateTime @updatedAt
}

model ContratoFile {
  id        String   @id @default(cuid())
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name      String
  mime      String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())

  @@index([unitId])
}
